---
import type { Project } from "../types";
import ProjectCard from "./ProjectCard.astro";

interface Props {
  projectsData: Project[];
}
const { projectsData } = Astro.props;
---

<section data-aos="fade-up" class="mb-32" id="projects">
  <div class="flex items-center gap-4 mb-12">
    <h2 class="font-headline-md text-headline-md text-on-surface">SELECTED_MODULES</h2>
    <div class="cyber-square-dot"></div>
    <div class="h-px grow bg-outline-variant"></div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    {projectsData.map((project) => (
      <ProjectCard project={project} />
    ))}
  </div>
</section>