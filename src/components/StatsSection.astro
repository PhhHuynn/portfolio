---
import type { StatItem } from "../types";

interface Props {
  statsData: StatItem[];
}
const { statsData } = Astro.props;
---

<section data-aos="fade-up" class="mb-32 grid grid-cols-2 md:grid-cols-4 gap-8">
  {statsData.map((stat) => (
    <div class="p-8 border border-outline-variant bg-surface-container-lowest flex flex-col gap-2 hover:border-primary-container hover:shadow-[0_0_15px_rgba(0,255,65,0.1)] transition-all duration-300 group">
      <span class="font-code-sm text-code-sm text-on-surface-variant group-hover:text-primary transition-colors">
        {stat.label}
      </span>
      <span
        class="stat-value text-headline-md font-bold text-primary-container group-hover:scale-110 origin-left transition-transform inline-block"
        data-target={stat.value}
      >
        0
      </span>
    </div>
  ))}
</section>

<script>
  // Chạy đúng 1 lần khi trang load - thay cho onMounted() + ref() của Vue.
  function startCounterAnimation(el: HTMLElement, targetValue: string, duration = 2000) {
    const numberMatch = targetValue.match(/^[\d.]+/);
    const suffixMatch = targetValue.match(/[^\d.]+$/);

    if (!numberMatch) {
      el.textContent = targetValue;
      return;
    }

    const target = parseFloat(numberMatch[0]);
    const suffix = suffixMatch ? suffixMatch[0] : "";
    const isDecimal = numberMatch[0].includes(".");
    const startTime = performance.now();

    function update(currentTime: number) {
      const elapsed = currentTime - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const eased = progress * (2 - progress);
      const current = eased * target;

      el.textContent = `${isDecimal ? current.toFixed(1) : Math.floor(current)}${suffix}`;

      if (progress < 1) requestAnimationFrame(update);
    }

    requestAnimationFrame(update);
  }

  document.querySelectorAll<HTMLElement>(".stat-value").forEach((el) => {
    const target = el.dataset.target ?? "0";
    startCounterAnimation(el, target);
  });
</script>