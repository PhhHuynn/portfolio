---
import type { CollectionEntry } from 'astro:content'

interface Props {
  project: CollectionEntry<'projects'>['data']
}
const { project } = Astro.props
const actionLinks = project.links.filter((link) => !link.href.startsWith("/projects/"))
---
<section class="mb-12">
  <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-8">
    <div>
      <div class="flex items-center gap-4 mb-2">
        {project.featured && (
          <span class="bg-primary-container text-on-primary-container px-3 py-1 font-label-caps text-label-caps">FEATURED</span>
        )}
        <span class="text-on-surface-variant font-code-sm text-code-sm">{project.terminal_path} // {project.version}</span>
      </div>
      <h1 class="font-display-lg-mobile md:text-display-lg font-display-lg text-primary leading-none uppercase tracking-tighter">
        {project.title}<span class="animate-flicker">_</span>
      </h1>
    </div>

    <div class="flex flex-wrap gap-4">
      {actionLinks.map((link) => (
        <a
          href={link.href}
          target="_blank"
          class:list={[
            'font-code-sm text-code-sm px-6 py-3 flex items-center gap-2 transition-all',
            link.isPrimary
              ? 'bg-primary-container text-on-primary-container'
              : 'border border-primary text-primary hover:bg-primary/10',
          ]}
        >
          <span class="material-symbols-outlined text-[18px]">{link.isPrimary ? 'terminal' : 'data_object'}</span>
          {link.label}
        </a>
      ))}
    </div>
  </div>

  {project.tags.length > 0 && (
    <div class="flex flex-wrap gap-2 border-t border-outline-variant pt-6">
      {project.tags.map((tag) => (
        <span class="px-3 py-1 border border-outline text-on-surface-variant font-code-sm text-code-sm bg-surface-container-low">#{tag}</span>
      ))}
    </div>
  )}
</section>
