---
interface Props {
  imageSrc?: string
  imageAlt?: string
}
const { imageSrc, imageAlt } = Astro.props
---
{imageSrc && (
  <section class="mb-16">
    <div class="border border-outline-variant bg-surface-container-lowest overflow-hidden group transition-all duration-300">
      <div class="terminal-header flex items-center justify-between px-4 py-2 border-b border-outline-variant bg-surface-container">
        <span class="font-code-sm text-code-sm text-on-surface-variant transition-colors group-hover:text-primary-container">
          ~/dashboard/overview.view
        </span>
        <div class="flex gap-1.5">
          <div class="w-2 h-2 rounded-full bg-error/20"></div>
          <div class="w-2 h-2 rounded-full bg-on-surface-variant/20"></div>
          <div class="w-2 h-2 rounded-full bg-primary-container/50 group-hover:bg-primary-container group-hover:shadow-[0_0_10px_rgba(0,255,65,0.8)] transition-all"></div>
        </div>
      </div>
      <div class="relative w-full bg-background">
        <img
          class="w-full h-full object-cover grayscale brightness-75 contrast-125 opacity-60 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700"
          src={imageSrc}
          alt={imageAlt ?? ''}
        />
      </div>
    </div>
  </section>
)}
