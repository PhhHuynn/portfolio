<footer
  class="z-10 w-full px-margin-mobile md:px-margin-desktop py-8 flex flex-col md:flex-row justify-between items-center gap-gutter border-t-2 border-outline-variant bg-surface-container-lowest"
>
  <div class="flex flex-col gap-2 items-center md:items-start">
    <span class="font-label-caps text-label-caps text-on-surface">SYSTEM READY // 2026</span>
    <span class="font-code-sm text-code-sm text-on-surface-variant uppercase">
      Design &amp; Engineering by Phương Huyền
    </span>
  </div>
  <div class="flex gap-gutter">
    <a class="font-code-sm text-code-sm text-on-surface-variant hover:text-primary-container transition-all cursor-pointer" href="#">GITHUB</a>
    <a class="font-code-sm text-code-sm text-on-surface-variant hover:text-primary-container transition-all cursor-pointer" href="#">LINKEDIN</a>
    <a class="font-code-sm text-code-sm text-on-surface-variant hover:text-primary-container transition-all cursor-pointer" href="#">DOCS</a>
    <a class="font-code-sm text-code-sm text-on-surface-variant hover:text-primary-container transition-all cursor-pointer" href="#">SOURCE</a>
  </div>
  <div class="font-code-sm text-code-sm text-primary-container">
    LOCAL_TIME:
    <span class="tabular-nums" id="clock">00:00:00</span>
  </div>
</footer>

<script>
  // Astro không "hydrate" component, nên logic DOM thuần viết thẳng ở đây,
  // chạy 1 lần lúc trang load trên trình duyệt - không cần onMounted/ref.
  const clock = document.getElementById("clock");
  if (clock) {
    setInterval(() => {
      const now = new Date();
      const hours = String(now.getHours()).padStart(2, "0");
      const minutes = String(now.getMinutes()).padStart(2, "0");
      const seconds = String(now.getSeconds()).padStart(2, "0");
      clock.textContent = `${hours}:${minutes}:${seconds}`;
    }, 1000);
  }
</script>