---
interface Props {
  type: 'DEVLOG' | 'THOUGHTS' | 'SYSTEM'
  title: string
  date: string
}
const { type, title, date } = Astro.props
---
<header class="mb-8 pb-6 border-b border-outline-variant">
  <div class="flex items-center gap-4 mb-4">
    <span class="bg-primary-container text-on-primary-container px-3 py-1 font-label-caps text-label-caps">{type}</span>
    <span class="text-on-surface-variant font-code-sm text-code-sm">{date}</span>
  </div>
  <h1 class="font-headline-md text-headline-md text-primary uppercase tracking-tight">{title}</h1>
</header>