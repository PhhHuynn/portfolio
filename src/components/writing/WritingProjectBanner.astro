---
interface Props {
  projectTitle: string
  projectSlug: string
}
const { projectTitle, projectSlug } = Astro.props
---
<a
  href={`/projects/${projectSlug}`}
  class="flex items-center gap-3 px-4 py-3 mb-8 border border-primary/30 bg-primary/5 hover:bg-primary/10 transition-colors font-code-sm text-code-sm"
>
  <span class="material-symbols-outlined text-primary text-[18px]">terminal</span>
  <span class="text-on-surface-variant">LOG_OF_PROJECT: <span class="text-primary">{projectTitle}</span></span>
</a>